<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<bean id="searchQueryInclude" class="org.openmrs.module.tasks.api.config.TestSearchQueryInclude" primary="true"/>

	<bean id="locationTypeTranslator"
		class="org.openmrs.module.tasks.api.config.TestLocationTypeTranslator"/>

	<bean id="observationReferenceRangeTranslator"
		class="org.openmrs.module.tasks.api.config.TestObservationReferenceRangeTranslator"/>

	<!-- Mock cacheInterceptor bean required by FHIR2 module -->
	<bean id="cacheInterceptor" class="org.openmrs.module.tasks.api.config.TestCacheInterceptor"/>

	<!-- Mock transactionInterceptor bean required by FHIR2 module -->
	<bean id="transactionInterceptor" class="org.springframework.transaction.interceptor.TransactionInterceptor">
		<property name="transactionManager" ref="transactionManager"/>
		<property name="transactionAttributeSource">
			<bean class="org.springframework.transaction.annotation.AnnotationTransactionAttributeSource"/>
		</property>
	</bean>

</beans>

